# ─── LLM (Gemini Realtime — continuous video AI) ────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Stream / Vision Agents SDK (WebRTC transport) ──────────
STREAM_API_KEY=
STREAM_API_SECRET=

# ─── TTS (whisper briefings to phone responders) ────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── Clawtunnel telephony (voice.clawtunnel.com) ────────────
CLAWTUNNEL_BASE_URL=https://voice.clawtunnel.com
CLAWTUNNEL_API_KEY=
CLAWTUNNEL_ARIA_EXTENSION=10001
CLAWTUNNEL_VOICE=en-US-JennyNeural
CLAWTUNNEL_CALLBACK_URL=

# ─── Camera (0 = default webcam, or path to video file) ─────
CAMERA_SOURCES=0
CAMERA_LOCATIONS=Main Lobby

# ─── Dashboard ───────────────────────────────────────────────
DASHBOARD_WS_PORT=8000

# ─── Telegram Alerts ─────────────────────────────────────────
# Get token from @BotFather, chat ID from getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Responder / Protocol config ─────────────────────────────
RESPONDERS_CONFIG=config/responders.yaml
PROTOCOLS_CONFIG=config/protocols.yaml
